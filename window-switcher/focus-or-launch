#!/bin/bash
# Focus an existing window matching PATTERN, or launch COMMAND.
# If multiple windows match, cycles through them on each invocation,
# ordered by most recently used first. The order is snapshotted on the
# first press and reused while presses keep coming within 2 seconds.
#
# A global z-order list (/tmp/focus-order) tracks all focused windows
# across apps. After every focus operation, restack-window enforces this
# order so windows stay in the correct visual position when switching apps.
#
# Usage: focus-or-launch [--class <wm-class>] <window-pattern> <launch-command>

USE_CLASS=false
CLASS=""

if [[ "$1" == "--class" ]]; then
  USE_CLASS=true
  CLASS="$2"
  shift 2
fi

PATTERN="$1"
COMMAND="$2"

if $USE_CLASS; then
  WINDOWS=$(xdotool search --classname "$CLASS" 2>/dev/null)
  STATE_KEY="$CLASS"
else
  WINDOWS=$(wmctrl -l | grep -i "$PATTERN" | awk '{print $1}')
  STATE_KEY="$PATTERN"
fi

if [[ -z "$WINDOWS" ]]; then
  eval "$COMMAND"
  exit 0
fi

WINDOW_COUNT=$(echo "$WINDOWS" | wc -l)

# Activate a window by ID, converting hex (wmctrl) to decimal (xdotool) if needed.
# --sync ensures GNOME has finished its own restacking before we apply corrections.
focus_window() {
  local id="$1"
  local dec_id
  if [[ "$id" =~ ^0x ]]; then
    dec_id=$(printf '%d' "$id")
  else
    dec_id="$id"
  fi
  xdotool windowactivate --sync "$dec_id"
}

# Move a window ID to the front (top) of the global z-order list.
update_focus_order() {
  local new_top="$1"
  local order_file="/tmp/focus-order"
  local current_ids=()

  [[ -f "$order_file" ]] && read -r -a current_ids < "$order_file"

  local filtered=()
  for id in "${current_ids[@]}"; do
    [[ "$id" != "$new_top" ]] && filtered+=("$id")
  done
  filtered+=("$new_top")

  echo "${filtered[*]}" > "$order_file"
}

# Re-apply the global z-order using restack-window (relative restacking).
apply_stacking() {
  [[ -f /tmp/focus-order ]] || return
  local order
  read -r order < /tmp/focus-order
  [[ -z "$order" ]] && return
  # shellcheck disable=SC2086
  restack-window $order 2>/dev/null || true
}

if [[ "$WINDOW_COUNT" -eq 1 ]]; then
  focus_window "$WINDOWS"
  update_focus_order "$WINDOWS"
  apply_stacking
  exit 0
fi

STATE_FILE="/tmp/focus-cycle-$(echo "$STATE_KEY" | tr ' /' '__')"
NOW=$(date +%s)

# Build current window ID set for membership checks
declare -A current_set
while IFS= read -r id; do
  current_set["$id"]=1
done <<< "$WINDOWS"

# Determine whether the snapshot is still valid (last press within 2s)
SNAPSHOT_VALID=false
saved_last=""
ordered=()

if [[ -f "$STATE_FILE" ]]; then
  { read -r saved_time; read -r saved_order_line; read -r saved_last; } < "$STATE_FILE"
  if (( NOW - saved_time < 2 )); then
    SNAPSHOT_VALID=true
    # Rebuild ordered list: keep saved IDs that still exist, append new ones
    for id in $saved_order_line; do
      [[ -n "${current_set[$id]+_}" ]] && ordered+=("$id")
    done
    for id in "${!current_set[@]}"; do
      already=false
      for o in "${ordered[@]}"; do [[ "$o" == "$id" ]] && already=true && break; done
      $already || ordered+=("$id")
    done
  fi
fi

if ! $SNAPSHOT_VALID; then
  # Fresh cycle: sort windows by _NET_WM_USER_TIME descending
  declare -A timestamps
  while IFS= read -r id; do
    ts=$(xprop -id "$id" _NET_WM_USER_TIME 2>/dev/null | grep -o '[0-9]*$')
    timestamps["$id"]="${ts:-0}"
  done <<< "$WINDOWS"

  mapfile -t ordered < <(
    for id in "${!timestamps[@]}"; do
      printf '%s %s\n' "${timestamps[$id]}" "$id"
    done | sort -rn | awk '{print $2}'
  )
  saved_last=""
fi

# Find next window in cycle (wrap around), skipping the active window.
# Normalize ACTIVE to match the ID format used by the window list:
#   xdotool search → decimal; wmctrl -l → hex (0x...)
ACTIVE_DEC=$(xdotool getactivewindow 2>/dev/null || echo "")
if [[ -n "$ACTIVE_DEC" ]]; then
  if $USE_CLASS; then
    ACTIVE="$ACTIVE_DEC"
  else
    ACTIVE=$(printf '0x%08x' "$ACTIVE_DEC")
  fi
else
  ACTIVE=""
fi
NEXT=""
FOUND=false
for id in "${ordered[@]}"; do
  if $FOUND; then
    if [[ "$id" != "$ACTIVE" ]]; then
      NEXT="$id"
      break
    fi
  fi
  [[ "$id" == "$saved_last" ]] && FOUND=true
done
if [[ -z "$NEXT" ]]; then
  for id in "${ordered[@]}"; do
    [[ "$id" != "$ACTIVE" ]] && NEXT="$id" && break
  done
fi

focus_window "$NEXT"

# Save cycle state — writing NOW resets the 2s inactivity clock
{
  echo "$NOW"
  echo "${ordered[*]}"
  echo "$NEXT"
} > "$STATE_FILE"

update_focus_order "$NEXT"
apply_stacking
